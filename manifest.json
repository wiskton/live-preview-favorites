{
  "manifest_version": 3,
  "name": "Live Preview + Favorites",
  "version": "4.0",
  "description": "Favorite streamers and see a side preview when hovering over them.",

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://www.twitch.tv/*",
    "https://twitch.tv/*",
    "https://player.twitch.tv/*",
    "https://decapi.me/*",
    "https://unavatar.io/*",
    "https://www.kick.com/*",
    "https://kick.com/*",
    "https://player.kick.com/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png"
    }
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.twitch.tv/*",
        "https://twitch.tv/*",
        "https://www.kick.com/*",
        "https://kick.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}